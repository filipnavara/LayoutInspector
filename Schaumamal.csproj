    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationIcon>Assets\appIcons\icon.ico</ApplicationIcon>
    <Version>1.1.1</Version>
    <AssemblyTitle>Schaumamal</AssemblyTitle>
    <Description>The second coming of UiAutomatorViewer.</Description>
