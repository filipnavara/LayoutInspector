<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Schaumamal.ViewModels"
             x:Class="Schaumamal.Views.ScreenshotLayer"
             x:DataType="vm:AppViewModel">
    <Border Padding="20" MaxWidth="450" MaxHeight="600"
            HorizontalAlignment="Left" VerticalAlignment="Center">
        <Panel x:Name="ScreenshotPanel" RenderTransformOrigin="0.5,0.5"
               PointerPressed="OnPointerPressed" PointerMoved="OnPointerMoved"
               PointerReleased="OnPointerReleased" PointerWheelChanged="OnPointerWheelChanged">
            <Panel.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                    <TranslateTransform X="0" Y="0" />
                </TransformGroup>
            </Panel.RenderTransform>
            <Image x:Name="ScreenshotImage" Stretch="Uniform" />
            <Canvas x:Name="HighlighterCanvas" IsHitTestVisible="False" />
        </Panel>
    </Border>
</UserControl>
