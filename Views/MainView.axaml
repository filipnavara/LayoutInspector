<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:Schaumamal.Views"
             xmlns:vm="using:Schaumamal.ViewModels"
             x:Class="Schaumamal.Views.MainView"
             x:DataType="vm:AppViewModel">
    <Panel Background="#121317">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <views:ScreenshotLayer Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20" />
            <views:ButtonLayer Grid.Row="0" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" />
            <views:PaneLayer Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Stretch" Margin="10" />
        </Grid>
        <views:FloatingWindowLayer />
        <views:NotificationLayer HorizontalAlignment="Center" VerticalAlignment="Bottom" />
    </Panel>
</UserControl>
