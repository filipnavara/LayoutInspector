<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:Schaumamal.Views"
             xmlns:vm="using:Schaumamal.ViewModels"
             x:Class="Schaumamal.Views.MainView"
             x:DataType="vm:AppViewModel">
    <Panel Background="#121317">
        <views:ScreenshotLayer HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20" />
        <views:ButtonLayer HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" />
        <views:PaneLayer HorizontalAlignment="Right" VerticalAlignment="Stretch" Margin="10" />
        <views:FloatingWindowLayer />
        <views:NotificationLayer HorizontalAlignment="Center" VerticalAlignment="Bottom" />
    </Panel>
</UserControl>
