<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Schaumamal.ViewModels"
             x:Class="Schaumamal.Views.PaneLayer"
             x:DataType="vm:AppViewModel">
    <Grid ColumnDefinitions="Auto,*" Margin="0,10">
        <!-- Vertical resize grip -->
        <Border Grid.Column="0" Width="20" Cursor="SizeWestEast" Background="Transparent"
                PointerPressed="OnVerticalWedgePressed" PointerMoved="OnVerticalWedgeMoved"
                PointerReleased="OnVerticalWedgeReleased">
            <Border Width="4" Height="40" CornerRadius="2" Background="#BBC3C6D2"
                    HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>

        <DockPanel Grid.Column="1">
            <!-- Upper pane: XML Tree -->
            <Border x:Name="UpperPane" DockPanel.Dock="Top" Height="300"
                    CornerRadius="20" BorderBrush="#1FFFFFFF" BorderThickness="1"
                    Background="#1E2024" ClipToBounds="True">
                <Panel>
                    <TextBlock x:Name="TreePlaceholder" Text="Missing layout."
                               Foreground="#71727B" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <ScrollViewer x:Name="TreeScroll" IsVisible="False"
                                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="TreeItems" Margin="10" />
                    </ScrollViewer>
                </Panel>
            </Border>

            <!-- Horizontal resize grip -->
            <Border DockPanel.Dock="Top" Height="20" Cursor="SizeNorthSouth" Background="Transparent"
                    PointerPressed="OnHorizontalWedgePressed" PointerMoved="OnHorizontalWedgeMoved"
                    PointerReleased="OnHorizontalWedgeReleased">
                <Border Width="40" Height="4" CornerRadius="2" Background="#BBC3C6D2"
                        HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>

            <!-- Lower pane: Node Properties -->
            <Border CornerRadius="20" BorderBrush="#1FFFFFFF" BorderThickness="1"
                    Background="#1E2024" ClipToBounds="True">
                <Panel>
                    <TextBlock x:Name="PropertiesPlaceholder" Text="No node selected."
                               Foreground="#71727B" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <ScrollViewer x:Name="PropertiesScroll" IsVisible="False"
                                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="PropertyItems" Margin="10" />
                    </ScrollViewer>
                </Panel>
            </Border>
        </DockPanel>
    </Grid>
</UserControl>
