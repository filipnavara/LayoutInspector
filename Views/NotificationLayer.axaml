<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Schaumamal.ViewModels"
             x:Class="Schaumamal.Views.NotificationLayer"
             x:DataType="vm:AppViewModel">
    <ItemsControl x:Name="NotificationStack" VerticalAlignment="Bottom" HorizontalAlignment="Center"
                  Margin="0,0,0,20" />
</UserControl>
